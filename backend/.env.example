# Copie para `.env.local` (gitignored) e preencha com seus valores.
# Use `supabase secrets set KEY=VALUE` para deploy.

# ── Supabase project (frontend lê via localStorage; o backend usa SERVICE_ROLE)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # NUNCA exponha — só Edge Functions

# ── Google OAuth (F2.2)
# Criar em https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxx-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Callback configurado no Google Console como "Authorized redirect URI":
GMAIL_REDIRECT_URI=https://YOUR-PROJECT.supabase.co/functions/v1/gmail-oauth/callback

# Para onde o usuário volta após o consent:
FRONTEND_REDIRECT_URI=https://edurcampos86-jpg.github.io/viagens/#gmail-connected

# ── Anthropic (F2.3 fallback de parser)
# Criar em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Kiwi Tequila (F3.4 monitor de preços)
KIWI_TEQUILA_API_KEY=xxxx

# ── HMAC secrets (gerar com: openssl rand -hex 32)
# Usado por gmail-oauth para assinar o state anti-CSRF.
OAUTH_STATE_SECRET=

# Usado pelos cron jobs (gmail-parser, price-monitor) para autenticar.
# O job chama a Edge Function com header `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ── Web Push (VAPID) — gerar com:
#   openssl ecparam -name prime256v1 -genkey -noout -out vapid.pem
#   openssl ec -in vapid.pem -pubout -outform DER | tail -c 65 | base64 | tr -d '=' | tr '/+' '_-'   # public
#   openssl ec -in vapid.pem -outform DER | dd bs=1 skip=7 count=32 2>/dev/null | base64 | tr -d '=' | tr '/+' '_-'   # private
# A public key vai pro frontend (window.WEBPUSH_VAPID_PUBLIC_KEY ou hard-code no SW).
# A private fica como secret só no backend.
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:edurcampos86@gmail.com
